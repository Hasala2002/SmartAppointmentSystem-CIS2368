# .env.example – copy to .env and fill in real values
#
# This file is the single source of truth for every environment variable used
# by docker-compose.local.yml (and docker-compose.production.yml).
# Docker Compose reads .env automatically when it exists in the same directory.

# ================================================================== #
# Database                                                             #
# ================================================================== #
# `db` is the compose service name – the API container reaches Postgres
# over the internal Docker network on that hostname.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/appointmentdb
DB_NAME=appointmentdb
DB_USER=postgres
DB_PASSWORD=postgres

# ================================================================== #
# JWT                                                                  #
# ================================================================== #
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ================================================================== #
# Application                                                          #
# ================================================================== #
APP_ENV=development
DEBUG=true

# Add every host:port your web/admin frontends are served on.
# Must match the WEB_PORT / ADMIN_PORT values below.
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# ================================================================== #
# Host port overrides                                                  #
# Change these if anything on your machine already uses those ports.  #
# ================================================================== #
DB_PORT=5432
API_PORT=8000
WEB_PORT=5173
ADMIN_PORT=5174

# ================================================================== #
# VAPID – Web Push Notifications                                       #
# Generate a key-pair once and store the values here.                 #
#                                                                      #
#   pip install py-vapid                                               #
#   python -c "                                                        #
#     from py_vapid import Vapid                                       #
#     v = Vapid()                                                      #
#     v.generate_keys()                                                #
#     print('PUBLIC :', v.public_key)                                  #
#     print('PRIVATE:', v.private_key)                                 #
#   "                                                                  #
#                                                                      #
# Leave blank to disable push notifications without errors.           #
# ================================================================== #
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@lonestardental.com

# ================================================================== #
# SMTP – Email Notifications                                           #
#                                                                      #
# Gmail setup (recommended for small deployments):                    #
#   1. Enable 2-Step Verification on your Google account              #
#   2. Go to: Google Account → Security → App Passwords               #
#   3. Create an app password for "Mail" / "Other"                    #
#   4. Paste the 16-character password (spaces don't matter) below    #
#                                                                      #
# All four values must be non-empty for emails to be sent.            #
# Leave them blank to silently skip email sending without errors.     #
# ================================================================== #
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_EMAIL=your-gmail@gmail.com
