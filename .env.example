# Database Configuration
# Use asyncpg driver: postgresql+asyncpg://postgres:postgres@db:5432/appointmentdb
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/appointmentdb
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Environment
APP_ENV=development
DEBUG=true

# CORS Origins for local development
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# SMTP Email Configuration (Optional - for email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
