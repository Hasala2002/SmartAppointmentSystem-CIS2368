# Database Configuration
# Use your Neon/external DB URL, or for local: postgresql://postgres:password@db:5432/appointmentdb
DATABASE_URL=postgresql://neondb_owner:your_password@your-host.neon.tech/neondb?sslmode=require
DB_PASSWORD=your_secure_password_here

# Domain Configuration (Required for Caddy)
# Replace these with your actual domains
API_DOMAIN=api.yourdomain.com
WEB_DOMAIN=app.yourdomain.com
ADMIN_DOMAIN=admin.yourdomain.com

# ACME (Let's Encrypt) Email for SSL certificates
ACME_EMAIL=your-email@example.com

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Environment
APP_ENV=production
DEBUG=false

# CORS Origins (auto-configured from domains above)
# This will be set to ["https://${WEB_DOMAIN}","https://${ADMIN_DOMAIN}"]
CORS_ORIGINS=["https://app.yourdomain.com","https://admin.yourdomain.com"]
